{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "compile with ImGui",
            "command": "g++",
            "args": [
                "-std=c++20",
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "${workspaceFolder}/dependencies/imgui/imgui.cpp",
                "${workspaceFolder}/dependencies/imgui/imgui_draw.cpp",
                "${workspaceFolder}/dependencies/imgui/imgui_tables.cpp",
                "${workspaceFolder}/dependencies/imgui/imgui_widgets.cpp",
                "${workspaceFolder}/dependencies/imgui/backends/imgui_impl_glfw.cpp",
                "${workspaceFolder}/dependencies/imgui/backends/imgui_impl_opengl3.cpp",
                "-I${workspaceFolder}/dependencies/libraries_and_backends",
                "-I", "${workspaceFolder}/dependencies/imgui",
                "-I", "${workspaceFolder}/dependencies/imgui/backends",
                "-I", "${workspaceFolder}/dependencies/GFLW/include",
                "-L", "${workspaceFolder}/dependencies/GFLW/glfw-3.4.bin.WIN64/lib-mingw-w64",
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",
                "-luser32",
                "-lshell32",
                "-lwinmm",
                "-limm32",
                "-lcomdlg32",
                "-o", "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
